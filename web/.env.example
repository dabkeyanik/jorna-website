# Copy to .env.local. All values are public (publishable) — no secrets here.

# Jorna backend (FastAPI on Railway). Point at a local backend for dev if you like.
NEXT_PUBLIC_API_BASE_URL=https://desiconnect-production.up.railway.app

# Supabase — only needed for Google OAuth (a later phase). The anon key is publishable.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
